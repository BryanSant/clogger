<configuration>
    <appender name="CLI" class="io.github.clilogger.CliLogAppender">
        <!-- COMPACT (default): colored middle-dot + message only.
             Switch to FULL for timestamp, thread, and level badge:
        <format>FULL</format>
        <datePattern>HH:mm:ss.SSS</datePattern>
        -->
    </appender>

    <root level="INFO">
        <appender-ref ref="CLI" />
    </root>
</configuration>
