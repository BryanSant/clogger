<configuration>
    <appender name="CLI" class="io.github.clogger.TuiLogAppender">
        <!-- Optional: customize the timestamp format (default: HH:mm:ss.SSS) -->
        <datePattern>HH:mm:ss.SSS</datePattern>
    </appender>

    <root level="TRACE">
        <appender-ref ref="CLI" />
    </root>
</configuration>
